{
    "name": "swipegames/integration-sdk",
    "description": "PHP SDK for Swipe Games platform integration",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "SwipeGames\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SwipeGames\\SDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
